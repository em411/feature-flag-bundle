{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block page_title 'Feature Flag' %}

{% block toolbar %}
    {% if 0 < collector.features|length %}
        {% set icon %}
            {{ source('@FeatureFlag/Collector/feature-flag.svg') }}
            <span class="sf-toolbar-value">{{ collector.features|length }}</span>
        {% endset %}

        {% set text %}
            <div class="sf-toolbar-info-piece">
                <b>Enabled</b>
                <span class="sf-toolbar-status  {{- collector.enabledCount ? ' sf-toolbar-status-green' }}">{{ collector.enabledCount }}</span>
            </div>

            <div class="sf-toolbar-info-piece">
                <b>Resolved</b>
                <span class="sf-toolbar-status  {{- collector.resolvedCount ? ' sf-toolbar-status-green' }}">{{ collector.resolvedCount }}</span>
            </div>

            <div class="sf-toolbar-info-piece">
                <b>Disabled</b>
                <span class="sf-toolbar-status {{- collector.disabledCount ? ' sf-toolbar-status-red' }}">{{ collector.disabledCount }}</span>
            </div>

            <div class="sf-toolbar-info-piece">
                <b>Not found</b>
                <span class="sf-toolbar-status sf-toolbar-status-grey">{{ collector.notFoundCount }}</span>
            </div>
        {% endset %}

        {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', {link: profiler_url}) }}
    {% endif %}
{% endblock %}

{% block menu %}
    <span class="label {{ collector.features|length is same as(0) ? 'disabled' }}">
        <span class="icon">{{ source('@FeatureFlag/Collector/feature-flag.svg') }}</span>
        <strong>Feature Flag</strong>
    </span>
{% endblock %}

{% block head %}
    {{ parent() }}
    <style>
        .badge {
            color: var(--white);
            display: inline-block;
            text-align: center;
            min-width: 100px;
        }
        .badge.badge-not_found {
            background-color: var(--gray-500);
        }
        .badge.badge-resolved {
            background-color: var(--green-500);
        }
        .badge.badge-enabled {
            background-color: var(--green-500);
        }
        .badge.badge-disabled {
            background-color: var(--red-500);
        }
    </style>
{% endblock %}

{% block panel %}
    <h2>Feature Flag</h2>
    {% if collector.features|length > 0 %}
        <table>
            <thead>
            <tr>
                <th>Feature name</th>
                <th>Enabled</th>
            </tr>
            </thead>
            <tbody>
            {% for feature_name, info in collector.features %}
                <tr>
                    <td>
                        {{ feature_name }}
                    </td>
                    <td>
                        {% set context_id = 'context-' ~ loop.index %}
                        <div>
                            <span class="badge badge-{{ info.status }}">{{ info.status|capitalize|replace({_: ' '}) }}</span>
                            <span><button type="button" class="btn btn-link text-small sf-toggle" data-toggle-selector="#{{ context_id }}" data-toggle-alt-content="Hide details">Show details</button></span>
                        </div>

                        <div id="{{ context_id }}" class="context sf-toggle-content sf-toggle-hidden">
                            <table>
                                <tr>
                                    <th>Value</th>
                                    <td>{{ profiler_dump(info.value, maxDepth: 2) }}</td>
                                </tr>
                                <tr>
                                    <th>Calls</th>
                                    <td>{{ info.calls }}</td>
                                </tr>
                            </table>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="empty">
            <p>No features resolved</p>
        </div>
    {% endif %}
{% endblock %}
